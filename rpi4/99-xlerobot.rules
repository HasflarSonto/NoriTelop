# XLeRobot Feetech bus udev rules — installed at /etc/udev/rules.d/99-xlerobot.rules
#
# Match by the CH343's USB serial number (ATTRS{serial}) so the symlink
# stays stable across reboots regardless of which USB port the board is
# plugged into. The two CH343 USB-Single-Serial boards enumerate as
# /dev/ttyACM* on mainline Linux (cdc_acm driver), not /dev/ttyUSB*.
#
# setup_pi.sh rewrites this file with the actual serials it discovered.
#
# To discover a serial manually:
#   udevadm info -q property -n /dev/ttyACM0 | grep ID_SERIAL_SHORT

SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="55d3", ATTRS{serial}=="__BUS1_SERIAL__", SYMLINK+="xlerobot_bus1", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="55d3", ATTRS{serial}=="__BUS2_SERIAL__", SYMLINK+="xlerobot_bus2", MODE="0660", GROUP="dialout"
